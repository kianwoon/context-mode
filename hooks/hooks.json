{
  "description": "Context-mode hooks — PreToolUse deny/redirect for high-output tools, PostToolUse FTS5 indexing for MCP tools",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/bash-output-guard.cjs"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/log-read-guard.cjs"
          }
        ]
      },
      {
        "matcher": "WebFetch|webReader|mcp__web_reader__webReader",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/web-fetch-guard.cjs"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__plugin_context-mode_context-mode__execute|mcp__plugin_context-mode_context-mode__batch_execute|mcp__plugin_context-mode_context-mode__fetch_and_index",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/posttooluse-indexer.cjs"
          }
        ]
      }
    ]
  }
}
