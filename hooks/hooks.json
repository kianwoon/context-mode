{
  "description": "Context-mode hooks — PreToolUse redirect for raw HTML + universal PostToolUse auto-indexer for large output",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "WebFetch|webReader",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/web-fetch-guard.cjs"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Read|WebSearch|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/posttooluse-indexer.cjs"
          }
        ]
      }
    ]
  }
}
