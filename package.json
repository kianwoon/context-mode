{
  "name": "context-mode",
  "version": "2.4.1",
  "type": "module",
  "description": "Sandboxed code execution + FTS5 knowledge base. 4 MCP tools, 2 auto-enforcing hooks.",
  "author": "Kian Woon",
  "license": "Elastic-2.0",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "context-window",
    "sandbox",
    "code-execution",
    "fts5",
    "bm25"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/kianwoon/context-mode"
  },
  "homepage": "https://github.com/kianwoon/context-mode#readme",
  "bugs": "https://github.com/kianwoon/context-mode/issues",
  "main": "./build/index.js",
  "exports": {
    ".": "./build/index.js"
  },
  "files": [
    "build",
    "hooks",
    ".claude-plugin",
    ".mcp.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && rm -rf build && esbuild src/index.ts --bundle --platform=node --target=node18 --format=esm --outfile=build/index.js --external:better-sqlite3 --minify",
    "dev": "npx tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "turndown": "^7.2.4",
    "zod": "^3.25.0"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.6.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.11",
    "@types/turndown": "^5.0.6",
    "esbuild": "^0.27.3",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
